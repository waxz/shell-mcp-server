FROM mcr.microsoft.com/windows/nanoserver:ltsc2025

# Create restricted workspace
WORKDIR C:\\workspace

# Enforce restrictive execution policy
RUN powershell -Command "Set-ExecutionPolicy Restricted -Scope LocalMachine -Force"

# Remove script execution
RUN powershell -Command "Set-ItemProperty -Path 'HKLM:\\Software\\Microsoft\\PowerShell\\1\\ShellIds\\Microsoft.PowerShell' -Name ExecutionPolicy -Value Restricted"

ENTRYPOINT ["pwsh"]